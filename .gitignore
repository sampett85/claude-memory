# Python
__pycache__/
*.pyc
.venv/

# User config (contains local paths)
config.env

# Runtime state (regenerated by scripts)
scripts/state.json
scripts/last-flush.json
scripts/flush.log
scripts/compile.log
scripts/session-flush-*
scripts/flush-context-*

# Raw daily logs (regenerated, can be large)
daily/

# Lint reports (regenerated)
reports/

# uv lock (regenerated by uv sync)
uv.lock

# Claude Code local settings
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db

# Obsidian metadata (if vault points here)
.obsidian/
