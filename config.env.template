# Claude Memory Configuration
# Copy this to config.env and customize

# Path to your Obsidian vault (~ is expanded automatically)
OBSIDIAN_VAULT=~/Desktop/Mister-Obsidian-Vault

# Your timezone (used for timestamps and compile-hour)
TIMEZONE=Asia/Kolkata

# Hour (24h) after which end-of-day compilation auto-triggers
COMPILE_AFTER_HOUR=18

# Project name: "auto" detects from parent directory, or set manually
PROJECT_NAME=auto
